# ExodoFlow AI — Variáveis de Ambiente
# Copiar para .env.local e preencher com os valores reais do projecto Supabase

# ── Supabase (obrigatório) ──────────────────────────────────────────────────
# URL pública do projecto Supabase (visível no browser — sem dados sensíveis)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Chave anónima do Supabase (visível no browser — acesso controlado por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Chave de serviço do Supabase (NUNCA expor no browser — apenas Edge Functions/servidor)
# Esta chave ignora RLS — usar com extrema cautela
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Aplicação ───────────────────────────────────────────────────────────────
# URL base da aplicação (sem barra final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Observabilidade (opcional) ──────────────────────────────────────────────
# DSN do Sentry. Quando definido, a camada de observabilidade (src/lib/observability.ts)
# passa a encaminhar erros para o Sentry. Vazio = apenas log estruturado local.
# NEXT_PUBLIC_SENTRY_DSN=

# ── WhatsApp Cloud API (Meta) ───────────────────────────────────────────────
# Token de verificação do webhook (Fase 1A)
# WHATSAPP_VERIFY_TOKEN=
# Em DEV permite webhooks sem assinatura (NUNCA em produção)
# WHATSAPP_WEBHOOK_ALLOW_UNSIGNED_DEV=true
#
# O access_token e o phone_number_id de cada tenant vivem em
# communication_channels.config (server-side) — NÃO em variáveis de ambiente.
#
# Modo mock (DEV/TEST): não chamam a Meta, gravam logs/mensagens na mesma.
# WHATSAPP_OUTBOUND_MOCK=true    # Fase 1B — resposta manual (texto livre 24h)
# WHATSAPP_TEMPLATE_MOCK=true    # Fase 1C — envio de template operacional
